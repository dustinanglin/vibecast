default_platform(:ios)

# Vibecast — fastlane lanes for TestFlight distribution.
#
# Auth is via App Store Connect API key (.p8). Required env vars:
#   APP_STORE_CONNECT_API_KEY_ID         e.g. ABCD1234EF
#   APP_STORE_CONNECT_API_KEY_ISSUER_ID  the team's issuer UUID
#   APP_STORE_CONNECT_API_KEY_PATH       absolute path to the .p8 file
#
# Locally: keep the .p8 outside the repo, e.g. ~/.appstoreconnect/AuthKey_*.p8.
# In CI: the .p8 is materialised from a base64-encoded GitHub secret into
# a temp file before the lane runs.

platform :ios do
  desc "Bootstrap or rotate the App Store cert+profile in the vibecast-certs repo. Run once locally."
  lane :setup_certs do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID"),
      key_filepath: ENV.fetch("APP_STORE_CONNECT_API_KEY_PATH")
    )
    # match's api_key_path parameter auto-binds to APP_STORE_CONNECT_API_KEY_PATH,
    # which conflicts with the api_key: hash we pass. Clear it for the call.
    ENV.delete("APP_STORE_CONNECT_API_KEY_PATH")
    match(type: "appstore", readonly: false, api_key: api_key)
  end

  desc "Build and upload a new TestFlight beta"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID"),
      key_filepath: ENV.fetch("APP_STORE_CONNECT_API_KEY_PATH"),
      duration: 1200,
      in_house: false
    )

    # Bump the build number to one past the most recent TestFlight build for
    # the current marketing version. No-ops if Apple hasn't seen the version
    # yet (returns 0 → next = 1).
    next_build = latest_testflight_build_number(api_key: api_key) + 1

    # Pass the build number as a build-time setting override rather than
    # modifying project.pbxproj on disk. This avoids leaving a transient
    # diff in the working tree and sidesteps the Info.plist substitution
    # that happens when fastlane's increment_build_number runs against a
    # project whose Info.plist references $(CURRENT_PROJECT_VERSION).
    # Pull the App Store distribution cert + provisioning profile out of the
    # vibecast-certs repo (managed by match). readonly: true so CI never
    # tries to mutate the cert pool — local creation/rotation is a separate
    # `bundle exec fastlane setup_certs` invocation.
    # See setup_certs note re: clearing APP_STORE_CONNECT_API_KEY_PATH.
    ENV.delete("APP_STORE_CONNECT_API_KEY_PATH")

    # In CI, install match's cert into a fresh ephemeral keychain we own.
    # Otherwise codesign later prompts for keychain unlock and hangs forever
    # because there's no UI on the runner.
    if ENV["CI"] == "true"
      keychain_name = "vibecast_ci_keychain"
      keychain_password = "vibecast-ephemeral-keychain"
      create_keychain(
        name: keychain_name,
        password: keychain_password,
        default_keychain: true,
        unlock: true,
        timeout: 3600,
        lock_when_sleeps: false
      )
      match(
        type: "appstore",
        readonly: true,
        api_key: api_key,
        keychain_name: keychain_name,
        keychain_password: keychain_password
      )
    else
      match(
        type: "appstore",
        readonly: true,
        api_key: api_key
      )
    end

    # match installs the profile under its actual stored name (sometimes
    # suffixed with a timestamp by Apple's API). Read the real name from
    # the env vars match exports rather than hard-coding "match AppStore
    # <bundle>" — that pattern doesn't match if there's a suffix.
    bundle_id = "AnglinVibes.Vibecast"
    profile_name = ENV.fetch("sigh_#{bundle_id}_appstore_profile-name")

    build_app(
      project: "Vibecast/Vibecast.xcodeproj",
      scheme: "Vibecast",
      configuration: "Release",
      output_directory: "build",
      output_name: "Vibecast.ipa",
      export_method: "app-store",
      # Manual signing pinned to the exact profile match installed.
      xcargs: [
        "CURRENT_PROJECT_VERSION=#{next_build}",
        "CODE_SIGN_STYLE=Manual",
        "DEVELOPMENT_TEAM=KLUX3TMK5S",
        "PROVISIONING_PROFILE_SPECIFIER=\"#{profile_name}\"",
        "CODE_SIGN_IDENTITY=\"Apple Distribution\""
      ].join(' '),
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        provisioningProfiles: {
          bundle_id => profile_name
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      # skip_waiting_for_build_processing: true — Apple's processing of the
      # uploaded .ipa happens server-side asynchronously; we don't need to
      # block CI on it. Internal-group distribution is a manual step in App
      # Store Connect (fastlane #22051: pilot's group-assign endpoint
      # currently 403s with "Access Unavailable" even for App-Manager-role
      # API keys).
      skip_waiting_for_build_processing: true,
      changelog: ENV["CHANGELOG"] || "Latest from main."
    )
  end
end
